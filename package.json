{
  "name": "nar_api",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.11.0"
  },
  "bin": {
    "nar_api": "bin/nar_api.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "TZ=UTC vitest run",
    "cdk": "cdk",
    "synth": "npm run compile && cdk synth",
    "deploy": "npm run compile && cdk deploy --require-approval never",
    "lint": "eslint .",
    "compile": "tsc",
    "fix": "eslint . --fix",
    "_prepare": "npm run compile",
    "pretest": "npm run synth > /dev/null",
    "posttest": "npm run lint"
  },
  "devDependencies": {
    "@smithy/util-stream": "^4.7.5",
    "@tsconfig/node24": "^24.0.4",
    "@types/aws-lambda": "^8.10.162",
    "@types/express": "^5.0.6",
    "@types/luxon": "^3.7.2",
    "@types/node": "^24",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "aws-cdk": "^2.1129.0",
    "aws-sdk-client-mock": "^4.0.1",
    "aws-sdk-client-mock-vitest": "^7.1.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.2",
    "eslint-config-flat-gitignore": "^2.3.0",
    "neostandard": "^0.13.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.33.1",
    "@aws-lambda-powertools/tracer": "^2.33.1",
    "@aws-sdk/client-s3": "^3.1078.0",
    "@aws-sdk/client-sfn": "^3.1078.0",
    "@aws-sdk/lib-storage": "^3.1078.0",
    "@codegenie/serverless-express": "^5.0.0",
    "@middy/core": "^7.7.0",
    "aws-cdk-lib": "^2.260.0",
    "axios": "^1.18.1",
    "cheerio": "^1.2.0",
    "constructs": "^10.6.0",
    "express": "^5.2.1",
    "luxon": "^3.7.2"
  }
}
